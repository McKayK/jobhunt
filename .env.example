# Copy to .env and edit. Used by docker compose.
HOME_ZIP=84057
RADIUS_MILES=30
INCLUDE_REMOTE=1
# Keep postings whose location text can't be geocoded (flagged "distance ?" in
# the UI). 1 = don't lose a possible local match; 0 = stricter board.
KEEP_UNKNOWN_LOCATIONS=1

# Empty = keep every title. Otherwise comma-separated substrings to KEEP.
TITLE_INCLUDE=

# Comma-separated substrings to DROP.
TITLE_EXCLUDE=intern,internship,vice president,chief 

# Nominatim asks for a real contact string. Put your email here.
USER_AGENT=jobhunt/0.1 (personal job search; contact: you@example.com)

# Hour (UTC) for the daily refresh. 13 = 6am Mountain (MDT), 14 = 6am MST.
REFRESH_HOUR_UTC=13
